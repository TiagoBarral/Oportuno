generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Opportunity {
  NO_WEBSITE
  WEAK_WEBSITE
  NONE
}

enum EmailStatus {
  SENT
  FAILED
}

enum JobStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

enum CompanyStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

model Company {
  id          String      @id @default(cuid())
  placeId     String      @unique
  name        String
  address     String?
  industry    String
  location    String
  websiteUrl  String?
  hasWebsite  Boolean     @default(false)
  opportunity Opportunity @default(NONE)
  email       String?
  phoneNumber String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  lastEnrichedAt  DateTime?

  emailLogs        EmailLog[]
  pipelineEntries  PipelineCompany[]

  @@index([industry])
  @@index([location])
  @@index([opportunity])
}

model PipelineJob {
  id        String    @id @default(cuid())
  industry  String
  location  String
  radius    Int
  status    JobStatus @default(PENDING)
  createdAt DateTime  @default(now())
  startedAt DateTime?
  finishedAt DateTime?

  companies PipelineCompany[]

  @@unique([industry, location])
}

model PipelineCompany {
  id        String        @id @default(cuid())
  jobId     String
  placeId   String
  name      String
  status    CompanyStatus @default(PENDING)
  error     String?
  companyId String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  job     PipelineJob @relation(fields: [jobId], references: [id])
  company Company?    @relation(fields: [companyId], references: [id])

  @@unique([jobId, placeId])
  @@index([jobId, status])
}

model EmailLog {
  id        String      @id @default(cuid())
  companyId String
  email     String
  subject   String
  body      String
  status    EmailStatus
  createdAt DateTime    @default(now())

  company   Company     @relation(fields: [companyId], references: [id])
}
