# Copy this file to .env.local and fill in your values.

# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/oportuno_db?schema=public"

# Google Places API key — https://console.cloud.google.com
GOOGLE_API_KEY=""

# Resend API key — https://resend.com
RESEND_API_KEY=""

# Verified sender address configured in Resend
RESEND_FROM_ADDRESS=""

# Set to "true" to skip Anthropic and use mock email generation (no API calls)
USE_MOCK_AI=true

# Anthropic API key — only required when USE_MOCK_AI is not "true"
ANTHROPIC_API_KEY=""
