#!/bin/sh
# Pre-commit hook — runs before every commit.
# Blocks the commit if tests fail or TypeScript reports errors.

cd app || exit 1

echo "Running tests..."
bun run test
if [ $? -ne 0 ]; then
  echo ""
  echo "Commit blocked: tests failed. Fix failing tests before committing."
  exit 1
fi

echo "Running type check..."
bunx tsc --noEmit
if [ $? -ne 0 ]; then
  echo ""
  echo "Commit blocked: TypeScript errors found. Fix type errors before committing."
  exit 1
fi

echo "All checks passed."
exit 0
